# Platform selection: "slack" or "discord"
PLATFORM=slack

# Slack credentials (required when PLATFORM=slack)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Discord credentials (required when PLATFORM=discord)
DISCORD_TOKEN=...

# Host path for the agent workspace (mounted into the container at /data; compose sets AGENT_DATA_DIR=/data inside the container).
# Put Agent Skills under ${AGENT_DATA_DIR}/.claude/skills/<name>/SKILL.md (same tree as cwd).
AGENT_DATA_DIR=/path/to/workspace

# --- Optional: concurrency and sessions ---
# Max concurrent agent turns across different conversation keys (default 8)
# MAX_CONCURRENT_AGENT_TURNS=8

# Persist thread_id -> Agent SDK session_id JSON (survives restarts). Use either:
# SESSIONS_JSON_PATH=/data/sessions.json
# or set PERSIST_SESSION_IDS=true to use ${AGENT_DATA_DIR}/sessions.json
# PERSIST_SESSION_IDS=true

# Discord: top-level (non-thread) conversation key — per_message | channel | channel_user
# DISCORD_TOP_LEVEL_KEY=per_message

# Slack: conversation key — thread_ts | channel | channel_user
# SLACK_KEY=thread_ts

# Line posted as "working" status before the agent replies (Slack / Discord).
# THINKING_PLACEHOLDER=🤔 Thinking...

# --- Optional: tool UX (Slack / Discord chat) ---
# Approval prompts (default on). Set false to auto-run tools without Approve/Deny.
# TOOL_APPROVAL_ENABLED=true
#
# Fine-grained chat feedback (each defaults to true). Legacy: TOOL_FEEDBACK_ENABLED=false
# sets the default for all three to false; override any flag with TOOL_FEEDBACK_*=true|false.
# TOOL_FEEDBACK_START=true              # "🔧 Using …" when approval is off
# TOOL_FEEDBACK_FINISH=true             # ✅/❌ on that line when the tool completes
# TOOL_FEEDBACK_APPROVAL_RESULT=true    # update the approval message after the tool runs
# TOOL_FEEDBACK_ENABLED=true            # legacy umbrella (optional)
#
# Flow: normal (default), update, or thinking_log.
# - update: with approval on, same message is edited approve → "Using …" → final result.
# - thinking_log: with TOOL_APPROVAL_ENABLED=false, tool lines append below THINKING_PLACEHOLDER;
#   final assistant reply is still a new message (Thinking unchanged).
#   Ignored while approval is on (use normal tool UI instead).
# TOOL_FEEDBACK_FLOW=normal
