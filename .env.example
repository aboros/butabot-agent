# Platform selection: "slack" or "discord"
PLATFORM=slack

# Slack credentials (required when PLATFORM=slack)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Discord credentials (required when PLATFORM=discord)
DISCORD_TOKEN=...

# Host path for the agent workspace (mounted into the container at /data; compose sets AGENT_DATA_DIR=/data inside the container)
AGENT_DATA_DIR=/path/to/workspace

# --- Optional: concurrency and sessions ---
# Max concurrent agent turns across different conversation keys (default 8)
# MAX_CONCURRENT_AGENT_TURNS=8

# Persist thread_id -> Agent SDK session_id JSON (survives restarts). Use either:
# SESSIONS_JSON_PATH=/data/sessions.json
# or set PERSIST_SESSION_IDS=true to use ${AGENT_DATA_DIR}/sessions.json
# PERSIST_SESSION_IDS=true

# Discord: top-level (non-thread) conversation key — per_message | channel | channel_user
# DISCORD_TOP_LEVEL_KEY=per_message

# Slack: conversation key — thread_ts | channel | channel_user
# SLACK_KEY=thread_ts
