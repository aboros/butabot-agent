# Fast Agent Secrets Configuration
# Copy this file to fastagent.secrets.yaml and fill in your actual values
# This file should be gitignored and not committed to version control

# Anthropic API Key (required)
ANTHROPIC_API_KEY: "${ANTHROPIC_API_KEY}"

# Slack Bot Token (required for Slack integration)
SLACK_BOT_TOKEN: "${SLACK_BOT_TOKEN}"

# Discord Bot Token (required for Discord integration)
DISCORD_TOKEN: "${DISCORD_TOKEN}"

# You can also use direct values (not recommended for production):
# ANTHROPIC_API_KEY: "sk-ant-your-key-here"
# SLACK_BOT_TOKEN: "xoxb-your-token-here"
# DISCORD_TOKEN: "your-discord-token-here"

