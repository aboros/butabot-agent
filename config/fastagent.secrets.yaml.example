# Fast Agent Secrets Configuration
# Copy this file to fastagent.secrets.yaml and fill in your actual values
# This file should be gitignored and not committed to version control
# Fast-agent automatically merges this file with fastagent.config.yaml

# ============================================================================
# LLM Provider API Keys
# ============================================================================

# Anthropic API Key (required for Claude models)
# Get your key from: https://console.anthropic.com/
anthropic:
  api_key: "${ANTHROPIC_API_KEY}"  # Or use direct value: "sk-ant-your-key-here"

# OpenAI API Key (required for GPT models)
# Get your key from: https://platform.openai.com/api-keys
openai:
  api_key: "${OPENAI_API_KEY}"  # Or use direct value: "sk-your-key-here"

# Hugging Face Token (for HF models and MCP servers)
# Get your token from: https://huggingface.co/settings/tokens
# Note: HF_TOKEN is automatically applied to HuggingFace MCP servers
hf:
  api_key: "${HF_TOKEN}"  # Or use direct value: "hf_your-token-here"

# Google API Key (for Gemini models)
# Get your key from: https://aistudio.google.com/app/apikey
google:
  api_key: "${GOOGLE_API_KEY}"

# Azure OpenAI (see fastagent.config.yaml for full configuration)
azure:
  api_key: "${AZURE_OPENAI_API_KEY}"

# Groq API Key
# Get your key from: https://console.groq.com/keys
groq:
  api_key: "${GROQ_API_KEY}"

# DeepSeek API Key
# Get your key from: https://platform.deepseek.com/
deepseek:
  api_key: "${DEEPSEEK_API_KEY}"

# XAI Grok API Key
# Get your key from: https://x.ai/
xai:
  api_key: "${XAI_API_KEY}"

# OpenRouter API Key
# Get your key from: https://openrouter.ai/keys
openrouter:
  api_key: "${OPENROUTER_API_KEY}"

# Aliyun API Key
aliyun:
  api_key: "${ALIYUN_API_KEY}"

# AWS Bedrock (uses standard AWS credentials - see fastagent.config.yaml)
# AWS credentials are typically configured via AWS CLI or environment variables:
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION

# ============================================================================
# MCP Server API Keys
# ============================================================================

# These are used in MCP server configurations in fastagent.config.yaml
# Example: Brave Search API Key
# BRAVE_API_KEY: "${BRAVE_API_KEY}"

# Example: Remote MCP Server API Key
# REMOTE_API_KEY: "${REMOTE_API_KEY}"

# Add other MCP server API keys as needed
# Use ${VAR_NAME} syntax to reference environment variables
# Or use direct values (not recommended for production)

# ============================================================================
# Platform Integration Secrets
# ============================================================================

# Slack Bot Token (required for Slack integration)
# Get your token from: https://api.slack.com/apps
SLACK_BOT_TOKEN: "${SLACK_BOT_TOKEN}"  # Or use direct value: "xoxb-your-token-here"

# Discord Bot Token (required for Discord integration)
# Get your token from: https://discord.com/developers/applications
DISCORD_TOKEN: "${DISCORD_TOKEN}"  # Or use direct value: "your-discord-token-here"

# ============================================================================
# Notes
# ============================================================================

# Environment Variable Substitution:
# - Use ${VAR_NAME} syntax to reference environment variables
# - Fast-agent will resolve these at runtime
# - This allows you to keep secrets in .env files or system environment

# Direct Values (Not Recommended):
# - You can use direct values instead of ${VAR_NAME}
# - Example: api_key: "sk-ant-your-key-here"
# - This is less secure and harder to manage

# Priority Order:
# 1. Direct values in fastagent.secrets.yaml
# 2. Environment variables (e.g., ANTHROPIC_API_KEY)
# 3. Values in fastagent.config.yaml (if not in secrets file)
